# Google Gemini (server-only)
GEMINI_API_KEY=

# Supabase (publiek — veilig voor de browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optioneel: alleen nodig als een route data namens de gebruiker moet schrijven
# zonder diens JWT. Standaard niet gebruikt (RLS via user-JWT).
# SUPABASE_SERVICE_ROLE_KEY=

# Push-notificaties (VAPID)
# Genereer eenmalig met: npx web-push generate-vapid-keys
# Sla de private key op als geheim — deel hem nooit publiek.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:koopman.janwillem@gmail.com
