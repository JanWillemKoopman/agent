# Google Gemini (server-only)
GEMINI_API_KEY=

# Supabase (publiek — veilig voor de browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key (server-only, NOOIT naar de browser). Vereist voor de gedeelde
# aanbiedingen-cache (daily_deals / deal_scrape_runs), die niet per gebruiker via
# RLS is afgeschermd en daarom server-side met de service-role wordt geschreven.
SUPABASE_SERVICE_ROLE_KEY=

# Push-notificaties (VAPID)
# Genereer eenmalig met: npx web-push generate-vapid-keys
# Sla de private key op als geheim — deel hem nooit publiek.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:koopman.janwillem@gmail.com
